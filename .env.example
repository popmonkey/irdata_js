# iRacing Proxy Server Configuration

# The port the server will listen on
PORT=80

# The base path where the application is served (e.g., /irdata_js)
BASE_PATH=/irdata_js

# The path to intercept for OAuth callback redirects
REDIRECT_PATH=/irdata_js/callback

# Allowed CORS Origin (default: *)
CORS_ORIGIN=*

# Rate Limiting Configuration (per 1 minute)
# Total requests across all users
GLOBAL_LIMIT=50
# Requests per individual IP
IP_LIMIT=5
# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
